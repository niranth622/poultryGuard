-- Enable RLS later
CREATE TABLE flocks (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  user_id UUID REFERENCES auth.users,
  name TEXT,
  breed TEXT,
  start_date DATE,
  initial_count INTEGER,
  current_count INTEGER,
  mortality_rate NUMERIC,
  fcr NUMERIC
);

